{
  "manifest_version": 3,
  "name": "YouTube Ad Skipper",
  "version": "1.0.0",
  "description": "Automatically clicks the Skip Ad button on YouTube within 3 seconds of it appearing.",

  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],

  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["constants.js", "content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YouTube Ad Skipper",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
